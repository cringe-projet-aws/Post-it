<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Post-its</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<header class="top-bar">
    <div class="brand">
        <span class="logo-square"></span>
        <span class="titre">Post-its</span>
    </div>
    <div class="auth">
        <% if (user) { %>
            <span class="bienvenue">Bonjour, <strong><%= user.username %></strong></span>
            <% if (user.can_admin) { %>
                <a href="/admin" class="btn btn-admin">Admin</a>
            <% } %>
            <a href="/logout" class="btn btn-secondary">Déconnexion</a>
        <% } else { %>
            <form action="/login" method="POST" class="login-form">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <input type="text" name="username" placeholder="Nom d'utilisateur" required maxlength="30">
                <input type="password" name="password" placeholder="Mot de passe" required>
                <button type="submit" class="btn btn-primary">Connexion</button>
                <a href="/signup" class="lien-petit">Inscription</a>
            </form>
        <% } %>
    </div>
</header>

<main id="tableau" class="tableau">

    <% if (erreur && erreur.length > 0) { %>
        <div class="flash flash-erreur">
            <% erreur.forEach(function(m) { %><div><%= m %></div><% }); %>
        </div>
    <% } %>
    <% if (succes && succes.length > 0) { %>
        <div class="flash flash-succes">
            <% succes.forEach(function(m) { %><div><%= m %></div><% }); %>
        </div>
    <% } %>

    <div class="aide">
        <% if (user) { %>
            Double-cliquez n'importe où pour créer un post-it
        <% } else { %>
            Connectez-vous pour créer des post-its
        <% } %>
    </div>

    <% postits.forEach(function(p) { %>
        <div class="postit"
             id="postit-<%= p.id %>"
             data-id="<%= p.id %>"
             data-auteur="<%= p.auteur_id %>"
             style="left: <%= p.x %>px; top: <%= p.y %>px; z-index: <%= p.z_index %>;">
            <div class="postit-header">
                <span class="postit-auteur"><%= p.auteur_nom %></span>
                <span class="postit-date"><%= new Date(p.created_at).toLocaleDateString('fr-FR') %></span>
                <% if (user && (user.id === p.auteur_id || user.can_admin)) { %>
                    <button class="btn-icone btn-modifier" title="Modifier">✏️</button>
                    <button class="btn-icone btn-supprimer" title="Supprimer">✖</button>
                <% } %>
            </div>
            <div class="postit-texte"><%= p.texte %></div>
        </div>
    <% }); %>

</main>

<!-- fenêtre popup pour créer/modifier un postit -->
<div id="modal" style="display:none;">
    <div class="modal-contenu">
        <h3 id="modal-titre">Nouveau post-it</h3>
        <textarea id="modal-texte" rows="4" placeholder="Votre message..." maxlength="500"></textarea>
        <small id="compteur-chars">0 / 500</small>
        <div class="modal-boutons">
            <button id="modal-annuler" class="btn btn-secondary">Annuler</button>
            <button id="modal-sauver" class="btn btn-primary">Enregistrer</button>
        </div>
    </div>
</div>

<script>
    var CURRENT_USER = <%- JSON.stringify(user || null) %>;
    var CSRF_TOKEN = '<%= csrfToken %>';
</script>
<script src="/js/app.js"></script>
</body>
</html>
