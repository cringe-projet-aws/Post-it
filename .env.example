# Port du serveur
PORT=3000

# Session secret
SESSION_SECRET=your_secret_key_here_change_in_production

# Database
DATABASE_PATH=./postits.db

# Admin password (optionnel - laissez vide pour génération aléatoire au premier setup)
# Ou définir ici si vous voulez un mot de passe spécifique
ADMIN_PASSWORD=

# Environnement
NODE_ENV=development
